# Rendered by Ansible - do not edit by hand.
# Defines the always-on services for the dev VM:
#   - code-server        : browser VS Code
#   - filebrowser        : home dir file manager
#   - watchtower         : automatic image updates
#   - claude-agent-N     : sandboxed Claude Code instances
#   - ts-code / ts-files : tailscale sidecars exposing the above via MagicDNS

name: devvm

x-tailscale-sidecar: &tailscale-sidecar
  image: tailscale/tailscale:latest
  restart: unless-stopped
  cap_add: [NET_ADMIN, NET_RAW]
  devices: [/dev/net/tun]
  volumes:
    - /var/lib/tailscale
    - /dev/net/tun:/dev/net/tun

services:

  # -------- VS Code in the browser ----------------------------------------
  # Built from ../code-server-image, which extends codercom/code-server with
  # Node.js + Claude Code + mise so `claude`, `python`, `uv`, `node`, etc.
  # are all on PATH in the integrated terminal. {{ shared_workdir }} is
  # bind-mounted at the same absolute path as on the host so the working
  # directory is identical to what you see over SSH.
  code-server:
    build:
      context: ../code-server-image
      dockerfile: Dockerfile
      args:
        CODE_SERVER_VERSION: {{ code_server_version | default('latest') }}
    image: devvm/code-server:local
    restart: unless-stopped
    user: "{{ devvm_user_uid }}:{{ devvm_user_uid }}"
    environment:
      DOCKER_USER: "{{ devvm_user }}"
      PASSWORD_FILE: /run/secrets/code_password
      ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY}
    volumes:
      - /home/{{ devvm_user }}:/home/{{ devvm_user }}
      - {{ shared_workdir }}:{{ shared_workdir }}
      - /var/run/docker.sock:/var/run/docker.sock
    command: >
      --auth=none
      --bind-addr 0.0.0.0:8080
      {% for ext in code_server_extensions %}
      --install-extension {{ ext }}
      {% endfor %}
      {{ shared_workdir }}
    network_mode: "service:ts-code"

  ts-code:
    <<: *tailscale-sidecar
    hostname: devvm-code
    environment:
      TS_AUTHKEY: ${TS_AUTHKEY_CODE}
      TS_HOSTNAME: devvm-code
      TS_STATE_DIR: /var/lib/tailscale
      TS_SERVE_CONFIG: /config/code-serve.json
      TS_EXTRA_ARGS: "--advertise-tags=tag:devvm"
    volumes:
      - ./ts-code-state:/var/lib/tailscale
      - ./ts-code-config:/config

{% if webtop_enabled | default(false) %}
  # -------- Optional full Linux desktop in the browser -------------------
  # linuxserver/webtop (KasmVNC + Selkies) streams a full XFCE desktop to
  # any browser. PUID/PGID match the host devvm user so the container's
  # $HOME *is* the host's /home/{{ devvm_user }}. That is the key property
  # keeping all surfaces in sync: there is only one filesystem, one set of
  # dotfiles, one mise install, one git config, one .ssh directory, one
  # VS Code profile. Impossible to drift because nothing is duplicated.
  webtop:
    image: {{ webtop_image }}
    restart: unless-stopped
    # Webtop needs some capabilities for its desktop session manager.
    security_opt:
      - seccomp:unconfined
    environment:
      PUID: "{{ devvm_user_uid }}"
      PGID: "{{ devvm_user_uid }}"
      TZ: "{{ webtop_timezone }}"
      TITLE: "devvm desktop"
      # Extra apt packages to install on first boot (linuxserver mod).
      DOCKER_MODS: linuxserver/mods:universal-package-install
      INSTALL_PACKAGES: "{{ webtop_apt_packages | join('|') }}"
    volumes:
      # $HOME IS the host's /home/{{ devvm_user }} - that's the whole trick.
      - /home/{{ devvm_user }}:/config
      # Expose the shared workdir at the same absolute path so paths match
      # exactly what the SSH shell, code-server, and the agents see.
      - {{ shared_workdir }}:{{ shared_workdir }}
      # Docker socket so you can use docker / docker compose from inside
      # the desktop's terminal too, against the same daemon.
      - /var/run/docker.sock:/var/run/docker.sock
    shm_size: "2gb"     # browsers need this
    network_mode: "service:ts-desktop"

  ts-desktop:
    <<: *tailscale-sidecar
    hostname: devvm-desktop
    environment:
      TS_AUTHKEY: ${TS_AUTHKEY_DESKTOP}
      TS_HOSTNAME: devvm-desktop
      TS_STATE_DIR: /var/lib/tailscale
      TS_SERVE_CONFIG: /config/desktop-serve.json
      TS_EXTRA_ARGS: "--advertise-tags=tag:devvm"
    volumes:
      - ./ts-desktop-state:/var/lib/tailscale
      - ./ts-desktop-config:/config
{% endif %}

  # -------- Web-based file manager for home dir ---------------------------
  filebrowser:
    image: {{ filebrowser_image }}
    restart: unless-stopped
    user: "{{ devvm_user_uid }}:{{ devvm_user_uid }}"
    volumes:
      - /home/{{ devvm_user }}:/srv
      - ./filebrowser:/database
    network_mode: "service:ts-files"

  ts-files:
    <<: *tailscale-sidecar
    hostname: devvm-files
    environment:
      TS_AUTHKEY: ${TS_AUTHKEY_FILES}
      TS_HOSTNAME: devvm-files
      TS_STATE_DIR: /var/lib/tailscale
      TS_SERVE_CONFIG: /config/files-serve.json
      TS_EXTRA_ARGS: "--advertise-tags=tag:devvm"
    volumes:
      - ./ts-files-state:/var/lib/tailscale
      - ./ts-files-config:/config

  # -------- Claude agent pool --------------------------------------------
  # Each agent is a locked-down container with network-allowlist firewall
  # (lifted from anthropics/claude-code/.devcontainer/init-firewall.sh).
  # Safe to run `claude --dangerously-skip-permissions` inside.
{% for agent in claude_agents %}
  {{ agent.name }}:
    build:
      context: ../agent-image
      dockerfile: Dockerfile
    image: devvm/claude-agent:local
    restart: unless-stopped
    hostname: {{ agent.name }}
    cap_add: [NET_ADMIN]       # needed so init-firewall.sh can write ipset rules
    environment:
      ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY}
      AGENT_NAME: {{ agent.name }}
    volumes:
      # Per-agent scratch workspace (isolated).
      - {{ agent.workspace }}:/workspace
      # Common working directory at the same absolute path as the host so
      # anything produced here is immediately visible over SSH and inside
      # code-server. This is the hand-off point between the constrained
      # environment and the rest of the VM.
      - {{ shared_workdir }}:{{ shared_workdir }}
    working_dir: {{ shared_workdir }}
    # ttyd gives each agent a browser terminal on its own internal port;
    # a single reverse proxy in front (see ts-agents) exposes them all.
    command: >
      ttyd -p 7681 -W -c user:${CLAUDE_TERMINAL_PASSWORD:-changeme}
           bash -lc "cd {{ shared_workdir }} && claude --dangerously-skip-permissions"
{% endfor %}

  # -------- Watchtower: keep all of the above up to date ------------------
  watchtower:
    image: {{ watchtower_image }}
    restart: unless-stopped
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    command: >
      --cleanup
      --schedule "{{ watchtower_schedule }}"
      --label-enable
    labels:
      - com.centurylinklabs.watchtower.enable=true
